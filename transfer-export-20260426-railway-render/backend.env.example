APP_NAME=XETA
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

FRONTEND_URL=http://localhost:5173
FRONTEND_URL_STAGING=

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=xeta
DB_USERNAME=root
DB_PASSWORD=

# Clerk Authentication
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWT_LEEWAY=60
ADMIN_EMAILS=admin@example.com

# Resend Email (Support)
RESEND_API_KEY=
RESEND_FROM_ADDRESS=support@xeta.store
RESEND_SUPPORT_INBOX=support@xeta.store
# Optional: comma-separated support inbox list, e.g. support@xeta.store,ops@xeta.store

# File Storage (S3 / Cloudflare R2)
FILESYSTEM_DISK=local
SUPPORT_ATTACHMENTS_DISK=
SUPPORT_ATTACHMENTS_DIRECTORY=support-attachments
PRODUCT_ATTACHMENTS_DISK=
PRODUCT_ATTACHMENTS_DIRECTORY=products
PRODUCT_VARIANT_ATTACHMENTS_DIRECTORY=product-variants
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

LOG_CHANNEL=stack
LOG_LEVEL=debug
